<?xml version="1.0" encoding="UTF-8"?>
<sqls>
	<sql ID="jiari">
		<i ID="isExistGuid">
		    <![CDATA[
		        select count(1) from abs_jiari where rowguid={rowguid}
		    ]]>
		</i>
		
		<i ID="queryJiaRiListByJiari">
		    <![CDATA[
		        select rowguid,isjia from abs_jiari where $like_suffix(rowguid,jiari) and isjia='1'
		    ]]>
		</i>
		
		<i ID="delJiariByGuid">
		    <![CDATA[
		        delete from abs_jiari where rowguid={rowguid}
		    ]]>
		</i>
		
		
		
		
	</sql>
</sqls>